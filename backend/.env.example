# Supabase Configuration
# Copy this file to .env and fill in your actual Supabase credentials

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (found in Project Settings > API)
# Use the 'anon' key for client-side operations, or 'service_role' key for server-side operations
SUPABASE_KEY=your-supabase-anon-key-here
